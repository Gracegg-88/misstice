# ── Supabase ────────────────────────────────────────────────────────────────
# Copiez ce fichier en « .env.local » et remplissez avec les valeurs de votre
# projet Supabase :  Dashboard → Project Settings → API
#
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE-PROJET.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=VOTRE_CLE_ANON_PUBLIQUE

# ── Cloudinary (hébergement des images/vidéos d'inspiration) ────────────────
# Upload SIGNÉ : le secret reste côté serveur. Valeurs dans Cloudinary →
# Settings → API Keys (Cloud name, une API Key avec droit d'upload, + secret).
#
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=VOTRE_CLOUD_NAME
NEXT_PUBLIC_CLOUDINARY_API_KEY=VOTRE_API_KEY
CLOUDINARY_API_SECRET=VOTRE_API_SECRET

# ── Brevo SMTP (emails RSVP aux invités — sans domaine) ─────────────────────
# Brevo → SMTP & API → SMTP : login + clé SMTP (xsmtpsib-…).
# Senders → vérifiez une adresse expéditeur (une Gmail suffit, confirmée mail).
#
BREVO_SMTP_LOGIN=xxxxxx@smtp-brevo.com
BREVO_SMTP_KEY=xsmtpsib-...
BREVO_SENDER_EMAIL=votre-adresse-verifiee@exemple.com
BREVO_SENDER_NAME=Misstice
